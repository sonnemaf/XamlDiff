<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="XamlDiff.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:helpers="using:XamlDiff.Helpers"
      xmlns:local="using:XamlDiff.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="MyHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="Margin" Value="1,28,0,4" />
        </Style>

        <helpers:ElementThemeConverter x:Key="ElementThemeConverter" />

    </Page.Resources>

    <Grid Padding="0,20,0,0"
          RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel Margin="40,0,0,0"
                    Orientation="Horizontal"
                    Spacing="10">

            <!--<AppBarButton Icon="Back" Click="ButtonBack_Click" />-->

            <!--<Image Height="30"
                VerticalAlignment="Center"
                Source="/Assets/Images/Settings.png" />-->

            <TextBlock Style="{StaticResource TitleTextBlockStyle}"
                       Text="Settings" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">

            <StackPanel Padding="40,0,40,8"
                        Spacing="4">

                <TextBlock Style="{StaticResource MyHeaderTextBlockStyle}"
                           Text="Appearance" />

                <controls:SettingsCard HorizontalAlignment="Stretch"
                                       Description="Choose a color theme to give it more personality"
                                       Header="Customize theme">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  Glyph="&#xE790;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ComboBox SelectedIndex="{x:Bind ViewModel.Theme.Value, Converter={StaticResource ElementThemeConverter}, Mode=TwoWay}">
                        <ComboBoxItem Content="Windows default" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </controls:SettingsCard>

                <TextBlock Style="{StaticResource MyHeaderTextBlockStyle}"
                           Text="About" />

                <controls:SettingsExpander Description="© 2026 Reflection IT. All rights reserved."
                                           Header="XAML Diff"
                                           IsExpanded="False">
                    <controls:SettingsExpander.HeaderIcon>
                        <ImageIcon Source="{ThemeResource SettingIcon}" />
                    </controls:SettingsExpander.HeaderIcon>

                    <TextBlock Text="{x:Bind AppVersion}" />

                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard HorizontalContentAlignment="Left"
                                               ContentAlignment="Vertical">
                            <StackPanel Margin="0,4,0,12"
                                        Spacing="8">
                                <StackPanel.Resources>
                                    <Style TargetType="HyperlinkButton">
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </StackPanel.Resources>

                                <HyperlinkButton Content="Reflection IT Privacy Policy"
                                                 NavigateUri="https://reflectionit.nl/apps/privacy/en" />

                                <TextBlock Margin="0,8,0,0"
                                           Text="Credits" />

                                <HyperlinkButton Content=".NET Community Toolkit MVVM"
                                                 NavigateUri="https://github.com/CommunityToolkit/dotnet" />

                                <HyperlinkButton Content="Windows Community Toolkit"
                                                 NavigateUri="https://github.com/CommunityToolkit/Windows" />

                                <HyperlinkButton Content="MonacoEditor WinUI3"
                                                 NavigateUri="https://github.com/luttje/MonacoEditor.WinUI3" />

                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <HyperlinkButton Margin="0,6"
                                 Padding="0"
                                 Click="ButtonRate_Click"
                                 Content="Rate app" />

                <HyperlinkButton Padding="0"
                                 Content="More free apps"
                                 NavigateUri="ms-windows-store://publisher/?name=Reflection IT" />

                <HyperlinkButton Margin="0,6"
                                 Padding="0"
                                 Click="ButtonSupporMail_Click"
                                 Content="Send feedback" />

            </StackPanel>

        </ScrollViewer>
    </Grid>
</Page>
